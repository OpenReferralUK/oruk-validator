{
  "Serilog": {
    "Using": ["Serilog.Sinks.Console"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "System.Net.Http.HttpClient": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": ["FromLogContext"]
  },
  "AllowedHosts": "*",
  "Specification": {
    "BaseUrl": "https://openreferraluk.org/specifications/"
  },
  "Database": {
    "ConnectionString": "",
    "DatabaseName": "oruk-v3",
    "ServicesCollection": "services"
  },
  "FeedValidation": {
    "Enabled": false,
    "IntervalHours": 48,
    "RunAtMidnight": true
  },
  "SemanticDataAudit": {
    "Enabled": true,
    "MismatchThreshold": 0.4,
    "MinimumAlternativeGap": 0.25,
    "Llm": {
      "Enabled": false,
      "Provider": "AzureOpenAI",
      "Endpoint": "",
      "ApiKey": "",
      "DeploymentOrModel": "",
      "ApiVersion": "2024-10-21",
      "Temperature": 0.0,
      "MaxTokens": 300
    }
  },
  "Cache": {
    "Enabled": true,
    "ExpirationMinutes": 120,
    "MaxSizeMB": 100,
    "UseSlidingExpiration": true,
    "SlidingExpirationMinutes": 60
  },
  "SchemaResolution": {
    "WarnOnUnknownJsonSchemaDraft": true,
    "KnownJsonSchemaUrls": [
      "https://json-schema.org/draft/2020-12/schema",
      "https://json-schema.org/draft/2020-12/meta/core",
      "https://json-schema.org/draft/2020-12/meta/applicator",
      "https://json-schema.org/draft/2020-12/meta/unevaluated",
      "https://json-schema.org/draft/2020-12/meta/validation",
      "https://json-schema.org/draft/2020-12/meta/meta-data",
      "https://json-schema.org/draft/2020-12/meta/format-annotation",
      "https://json-schema.org/draft/2020-12/meta/content"
    ]
  },
  "SchemaWarmup": {
    "Enabled": true,
    "StartupDelaySeconds": 5,
    "Urls": [
      "https://openreferraluk.org/specifications/3.0/openapi.json",
      "https://openreferraluk.org/specifications/1.0/openapi.json",
      "https://raw.githubusercontent.com/openreferral/specification/refs/heads/3.2/schema/openapi.json"
    ]
  },
  "Authentication": {
    "AllowUserSuppliedAuth": true
  }
}